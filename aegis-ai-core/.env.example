# Aegis AI Core Environment Template
# Copy this to .env and fill in your actual credentials

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=aegis-kafka:9092
KAFKA_TOPIC=aegis.documents.raw
KAFKA_DLQ_TOPIC=aegis.documents.failed

# MinIO Configuration
MINIO_URL=aegis-minio:9000
MINIO_ACCESS_KEY=aegis_admin
MINIO_SECRET_KEY=aegis_password
MINIO_BUCKET=aegis-raw-docs

# Qdrant Configuration
QDRANT_URL=http://aegis-qdrant:6333
QDRANT_COLLECTION=aegis_documents

# AI API Keys (OpenRouter / Anthropic / OpenAI)
ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENAI_API_KEY=your_key_here
